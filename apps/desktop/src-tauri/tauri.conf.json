{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Irori",
  "version": "0.1.4",
  "identifier": "ai.irori.app",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Irori",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/sidecar",
      "resources/node"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Beiming Liu (MJFP85U8HQ)",
      "hardenedRuntime": true
    }
  }
}
