{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cockapoo Pi Companion",
  "version": "0.1.0",
  "identifier": "ai.cockapoo.pi-companion",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cockapoo Pi Companion",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
